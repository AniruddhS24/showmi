# LLM endpoint (vllm-mlx serving mlx-community/bu-30b-a3b-preview-8bit)
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=default
LLM_TEMPERATURE=0.6
LLM_API_KEY=not-needed

# Chrome CDP
CDP_URL=http://localhost:9222

# Agent settings
MAX_STEPS=100
MAX_ACTIONS_PER_STEP=4
MAX_FAILURES=3
USE_VISION=true

# Safety: prompt for confirmation before each agent step
REQUIRE_CONFIRMATION=false
