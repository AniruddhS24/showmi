# ── LLM (defaults — override via CLI: showmi models add) ──
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=default
LLM_TEMPERATURE=0.6
LLM_API_KEY=not-needed

# ── Agent ──
MAX_STEPS=100
MAX_ACTIONS_PER_STEP=4
MAX_FAILURES=3
USE_VISION=true
REQUIRE_CONFIRMATION=false

# Chrome is driven via the Showmi extension (chrome.debugger API).
# Open the sidepanel and click Attach to pick a tab — no --remote-debugging-port,
# no CDP_URL, no separate Chrome window.
